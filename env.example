# Vite: только такие префиксы попадают в бандл (см. vite.config)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Код входа: итоговый email = код + @ + домен. Должен совпадать с secret STAFF_EMAIL_DOMAIN у Edge create-staff
VITE_STAFF_AUTH_DOMAIN=om.staff

# Vercel: те же пары, либо (vite.config подмешает в build):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# После смены env в Vercel — Redeploy (Preview/Prod отдельно)
